# Copy to .env and fill in values. Then run: npm run run
# CLI options (--src, --coverage, --model, --concurrency, --recursion-limit) override these env vars.

SOURCE_FOLDER=/path/to/your/go/project
TARGET_COVERAGE=80
TARGET_MODEL=ollama
CONCURRENCY=2
GRAPH_RECURSION_LIMIT=50

# Optional: LangSmith
# LANGSMITH_API_KEY=...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=go-tests-agent
